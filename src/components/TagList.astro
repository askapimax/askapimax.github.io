---
interface Props {
  tags?: string[];
  compact?: boolean;
}

const { tags = [], compact = false } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class:list={["tags", { compact }]} aria-label="Tags">
      {tags.map((tag) => (
        <li>{tag}</li>
      ))}
    </ul>
  )
}

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 10px;
    border: 1px solid rgba(13, 107, 87, 0.22);
    border-radius: 999px;
    background: rgba(13, 107, 87, 0.07);
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 780;
    line-height: 1;
  }

  .compact li {
    min-height: 26px;
    font-size: 0.76rem;
  }
</style>
