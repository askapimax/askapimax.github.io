---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import TagList from "../../components/TagList.astro";
import { getAllTags, getPublishedPosts } from "../../lib/posts";

const posts = await getPublishedPosts();
const tags = await getAllTags();
---

<BaseLayout title="Blog" description="Alle veröffentlichten Einträge aus Max Digital Garden.">
  <header class="archive-hero container">
    <p class="eyebrow">Blog</p>
    <h1>Alle Einträge</h1>
    <p class="lede">Notizen, Essays und Projektfragmente, chronologisch gesammelt.</p>
    <TagList tags={tags} />
  </header>

  <section class="container archive-list" aria-label="Blogposts">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>

<style>
  .archive-hero {
    padding: 74px 0 34px;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 520;
    line-height: 0.98;
  }

  .lede {
    max-width: 620px;
    margin: 22px 0;
  }

  .archive-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    padding-bottom: 80px;
  }

  @media (max-width: 760px) {
    .archive-list {
      grid-template-columns: 1fr;
    }
  }
</style>
